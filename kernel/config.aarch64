# zigllm-os kernel configuration — aarch64 (Raspberry Pi 5 / Jetson)

# --- Scheduler / Latency ---
CONFIG_HZ_1000=y
CONFIG_HZ=1000
CONFIG_PREEMPT=y
CONFIG_NO_HZ_FULL=y

# --- Memory ---
CONFIG_TRANSPARENT_HUGEPAGE=y
CONFIG_HUGETLBFS=y
CONFIG_ZSWAP=y

# --- GPU / DRM ---
CONFIG_DRM=y
CONFIG_DRM_KMS_HELPER=y
CONFIG_DRM_VC4=y        # Raspberry Pi 4/5 VideoCore
CONFIG_DRM_TEGRA=y      # Jetson / Tegra
CONFIG_FB=y
CONFIG_FB_SIMPLE=y

# --- Input ---
CONFIG_INPUT=y
CONFIG_INPUT_EVDEV=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_INPUT_MOUSE=y
CONFIG_INPUT_TOUCHSCREEN=y
CONFIG_HID=y
CONFIG_USB_HID=y

# --- Storage ---
CONFIG_EXT4_FS=y
CONFIG_VFAT_FS=y
CONFIG_MMC=y
CONFIG_MMC_SDHCI=y
CONFIG_MMC_SDHCI_PLTFM=y
CONFIG_USB_STORAGE=y

# --- Networking ---
CONFIG_NET=y
CONFIG_INET=y

# --- USB ---
CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y

# --- Firmware ---
CONFIG_FW_LOADER=y
CONFIG_EXTRA_FIRMWARE_DIR="/lib/firmware"

# --- Strip ---
# CONFIG_SOUND is not set
# CONFIG_BLUETOOTH is not set
# CONFIG_WIRELESS is not set
