# /etc/magister/env — copy to /etc/magister/env and fill in values
# All variables are loaded by s6-envfile before exec.

# ── Required ──────────────────────────────────────────────────────────────────

# Flat-file storage root. Must exist and be writable by the magister user.
GRIM_DATA_PATH=/var/lib/magister

# Deployment profile. "local" = scrypt+HS256. "cloud" = Ed25519+JWKS.
# This is a runtime hint only — the binary is compiled with a fixed profile.
# Ensure the installed binary matches the profile you set here.
MAGISTER_PROFILE=local

# ── DGB Node RPC ──────────────────────────────────────────────────────────────

MAGISTER_RPC_HOST=127.0.0.1
MAGISTER_RPC_PORT=14022
MAGISTER_RPC_USER=rpcuser
MAGISTER_RPC_PASS=rpcpassword

# ── Ports ─────────────────────────────────────────────────────────────────────

MAGISTER_STRATUM_PORT=3333
MAGISTER_API_PORT=8080

# ── Advisor ───────────────────────────────────────────────────────────────────

# T0 = single-coin baseline (default)
# T1 = multi-coin parallel (one suggestion per live coin per party per cycle)
MAGISTER_ADVISOR_TIER=T0
